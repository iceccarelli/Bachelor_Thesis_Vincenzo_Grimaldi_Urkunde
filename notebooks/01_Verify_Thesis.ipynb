   "source": [
    "# 01_Verify_Thesis.ipynb: Bachelor's Thesis Verification"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "This notebook provides a step-by-step process to verify the details of Vincenzo Grimaldi's Bachelor's thesis against the provided PDF document. It demonstrates the extraction of key information and its validation."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import os\n",
    "from pypdf import PdfReader\n",
    "\n",
    "# Define paths\n",
    "BASE_PATH = os.path.abspath(os.path.join(os.getcwd(), os.pardir))\n",
    "THESIS_PATH = os.path.join(BASE_PATH, 'BA_Ceccarelli_Complete_1.pdf')\n",
    "KEY_DETAILS_CSV = os.path.join(BASE_PATH, 'data', 'key_details.csv')\n",
    "\n",
    "def extract_text_from_pdf(pdf_path):\n",
    "    text = \"\"\n",
    "    try:\n",
    "        reader = PdfReader(pdf_path)\n",
    "        for page in reader.pages:\n",
    "            text += page.extract_text()\n",
    "    except Exception as e:\n",
    "        print(f\"Error extracting text from {pdf_path}: {e}\")\n",
    "    return text\n",
    "\n",
    "# 1. Extract text from the thesis PDF\n",
    "thesis_text = extract_text_from_pdf(THESIS_PATH)\n",
    "\n",
    "print(\"--- Extracted Text from BA_Ceccarelli_Complete_1.pdf ---\")\n",
    "print(thesis_text[:1000]) # Print first 1000 characters for review\n",
    "\n",
    "# 2. Load key_details.csv\n",
    "key_details_df = pd.read_csv(KEY_DETAILS_CSV)\n",
    "print(\"\n--- Loaded Key Details from CSV ---\")\n",
    "print(key_details_df.head())\n",
    "\n",
    "# 3. Verify key details against extracted PDF text\n",
    "def verify_detail(section, key, expected_value):\n",
    "    if expected_value is None: return True # Skip if no expected value\n",
    "    if expected_value in thesis_text:\n",
    "        print(f\"[PASS] {section} - {key}: '{expected_value}' found in PDF.\")\n",
    "        return True\n",
    "    else:\n",
    "        print(f\"[FAIL] {section} - {key}: '{expected_value}' NOT found in PDF.\")\n",
    "        return False\n",
    "\n",
    "verification_results = []\n",
    "for index, row in key_details_df.iterrows():\n",
    "    section = row['section']\n",
    "    key = row['detail_key']\n",
    "    value = str(row['detail_value']).strip() if pd.notna(row['detail_value']) else None\n",
    "    verification_results.append(verify_detail(section, key, value))\n",
    "\n",
    "if all(verification_results):\n",
    "    print(\"\n--- ALL KEY DETAILS VERIFIED SUCCESSFULLY AGAINST THESIS PDF CONTENT ---\")\n",
    "else:\n",
    "    print(\"\n--- SOME KEY DETAILS FAILED VERIFICATION AGAINST THESIS PDF CONTENT ---\")\n"
   ]
  },
  {
